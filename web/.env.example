# Connexion Postgres (injectée automatiquement par Vercel Postgres en prod).
# En local, copier ce fichier en .env.local et renseigner la valeur.
POSTGRES_URL="postgresql://user:password@host/db?sslmode=require"

# Secret partagé entre le site et l'extension Chrome (en-tête Authorization: Bearer ...)
API_SECRET="change-moi-secret-long-et-aleatoire"

# Mot de passe d'accès au site web
SITE_PASSWORD="change-moi-mot-de-passe"
